                <stringProp name="Header.name">User-Agent</stringProp>
                <stringProp name="Header.value">Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <hashTree/>
          <HtmlExtractor guiclass="HtmlExtractorGui" testclass="HtmlExtractor" testname="CSS Selector Extractor">
            <stringProp name="HtmlExtractor.refname">productName</stringProp>
            <stringProp name="HtmlExtractor.expr">a.product-item h2.product-item-title</stringProp>
            <stringProp name="HtmlExtractor.attribute"></stringProp>
